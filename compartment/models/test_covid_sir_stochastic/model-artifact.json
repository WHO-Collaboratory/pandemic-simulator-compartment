{
  "disease_type": "COVID_SIR_STOCHASTIC",
  "disease_label": "COVID-19 Stochastic SIR",
  "description": "A simple stochastic SIR model for COVID-19",
  "compartments": [
    {
      "id": "S",
      "label": "Susceptible",
      "description": "Population susceptible to infection",
      "infective": false
    },
    {
      "id": "I",
      "label": "Infected",
      "description": "Currently infected population",
      "infective": true
    },
    {
      "id": "R",
      "label": "Recovered",
      "description": "Recovered and immune population",
      "infective": false
    }
  ],
  "transmission_edges": [
    {
      "source": "susceptible",
      "target": "infected",
      "variable_name": "beta",
      "parameter": {
        "name": "transmission_rate",
        "label": "Transmission Rate (S->I)",
        "description": "Rate at which susceptible individuals become infected",
        "value_type": "rate",
        "default": 0.4,
        "min_value": 0.01,
        "max_value": 2.0,
        "default_min": 0.2,
        "default_max": 0.6,
        "required": true,
        "unit": "per day"
      },
      "frequency_dependent": true
    },
    {
      "source": "infected",
      "target": "recovered",
      "variable_name": "gamma",
      "parameter": {
        "name": "transmission_rate",
        "label": "Recovery Period (I->R)",
        "description": "Average number of days for an infected individual to recover",
        "value_type": "days",
        "default": 7.0,
        "min_value": 1.0,
        "max_value": 30.0,
        "default_min": 5.0,
        "default_max": 14.0,
        "required": true,
        "unit": "days"
      },
      "frequency_dependent": false
    }
  ],
  "interventions": [],
  "travel_volume": null,
  "admin_zone_fields": [],
  "disease_parameters": [],
  "simulation_parameters": [
    {
      "name": "start_date",
      "label": "Start Date",
      "description": "Simulation start date",
      "value_type": "date",
      "required": true
    },
    {
      "name": "end_date",
      "label": "End Date",
      "description": "Simulation end date",
      "value_type": "date",
      "required": true
    },
    {
      "name": "run_mode",
      "label": "Run Mode",
      "description": "Run a single deterministic simulation or uncertainty analysis with multiple runs",
      "value_type": "select",
      "default": "DETERMINISTIC",
      "required": true,
      "options": [
        "DETERMINISTIC",
        "UNCERTAINTY"
      ]
    },
    {
      "name": "simulation_type",
      "label": "Simulation Type",
      "description": "Type of simulation engine",
      "value_type": "select",
      "default": "COMPARTMENTAL",
      "required": true,
      "options": [
        "COMPARTMENTAL",
        "AGENT_BASED"
      ]
    }
  ]
}